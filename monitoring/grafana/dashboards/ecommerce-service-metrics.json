{
  "uid": "cfrozpgpnfe2oa",
  "title": "E-Commerce Service Request Metrics",
  "tags": [
    "ecommerce",
    "service-metrics",
    "api",
    "microservices",
    "docker"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
