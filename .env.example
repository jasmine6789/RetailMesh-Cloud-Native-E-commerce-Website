# ==================================================================
# Cloud-Native E-commerce Platform - Environment Configuration
# ==================================================================
# Copy this file to .env and update the values according to your environment
# For production deployment, ensure all passwords are secure and unique

# ==================================================================
# MongoDB Configuration (Catalog Service)
# ==================================================================
# MongoDB credentials for the catalog service database
MONGO_USER=admin
MONGO_PASSWORD=admin1234
MONGO_DB=CatalogDb

# ==================================================================
# PostgreSQL Configuration (Discount Service)
# ==================================================================
# PostgreSQL credentials for the discount service database
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin1234
POSTGRES_DB=DiscountDb

# ==================================================================
# SQL Server Configuration (Ordering Service)
# ==================================================================
# SQL Server credentials for the ordering service database
SQL_SA_PASSWORD=SqlPassword123
SQL_DB=OrderDb
ACCEPT_EULA=Y

# ==================================================================
# Redis Configuration (Basket Service)
# ==================================================================
# Redis is used for basket/session storage
# No authentication required for development setup
REDIS_HOST=basketdb
REDIS_PORT=6379

# ==================================================================
# RabbitMQ Configuration (Message Broker)
# ==================================================================
# RabbitMQ credentials for inter-service communication
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ==================================================================
# Elasticsearch Configuration (Logging & Monitoring)
# ==================================================================
# Elasticsearch settings for centralized logging
ES_JAVA_OPTS=-Xms512m -Xmx512m
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ==================================================================
# Kibana Configuration (Log Visualization)
# ==================================================================
# Kibana for Elasticsearch data visualization
KIBANA_HOST=kibana
KIBANA_PORT=5601

# ==================================================================
# pgAdmin Configuration (PostgreSQL Management)
# ==================================================================
# pgAdmin web interface credentials for PostgreSQL management
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin1234

# ==================================================================
# Kiali Configuration (Service Mesh Observability)
# ==================================================================
# Kiali credentials for Istio service mesh visualization
# Note: These are base64 encoded values
KIALI_USERNAME_BASE64=YWRtaW4=              # admin
KIALI_PASSWORD_BASE64=YWRtaW4xMjM0          # admin1234

# ==================================================================
# Application Environment
# ==================================================================
# ASP.NET Core environment setting
ASPNETCORE_ENVIRONMENT=Development

# ==================================================================
# Docker Registry Configuration
# ==================================================================
# Docker registry for custom images (leave empty for local builds)
DOCKER_REGISTRY=

# ==================================================================
# Connection Strings (Auto-generated from above variables)
# ==================================================================
# These connection strings are constructed from the variables above
# MongoDB connection string for catalog service
MONGODB_URL=mongodb://admin:admin1234@catalogdb:27017/CatalogDb?authSource=admin

# Redis connection string for basket service
REDIS_URL=basketdb:6379

# PostgreSQL connection string for discount service
POSTGRES_URL=Server=discountdb;Port=5432;Database=${POSTGRES_DB};User Id=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Pooling=true;SSL Mode=Disable;

# SQL Server connection string for ordering service
SQLSERVER_URL=Server=orderdb;Database=${SQL_DB};User Id=sa;Password=${SQL_SA_PASSWORD};TrustServerCertificate=True

# SQL Server connection string for identity service
IDENTITY_DB=IdentityDb
IDENTITY_CONNECTION_STRING=Server=orderdb;Database=${IDENTITY_DB};User Id=sa;Password=${SQL_SA_PASSWORD};TrustServerCertificate=True

# RabbitMQ connection string for message broker
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672

# Elasticsearch URL for logging
ELASTICSEARCH_URL=http://elasticsearch:9200

# ==================================================================
# Service Ports (for reference)
# ==================================================================
# API Gateway
OCELOT_GATEWAY_PORT=8010

# Microservices
CATALOG_API_PORT=8000
BASKET_API_PORT=8001
DISCOUNT_API_PORT=8002
ORDERING_API_PORT=8003
IDENTITY_API_PORT=8004

# Frontend
ANGULAR_CLIENT_PORT=4200

# ==================================================================
# Monitoring & Observability Ports
# ==================================================================
# Prometheus metrics
PROMETHEUS_PORT=9090

# Grafana dashboards
GRAFANA_PORT=3000

# Jaeger tracing
JAEGER_PORT=16686

# ==================================================================
# Monitoring & Grafana Defaults (Docker Compose)
# ==================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin1234

# OpenTelemetry exporter endpoint for Jaeger (gRPC/OTLP)
OTLP_ENDPOINT=http://jaeger:4317

# Optional tuning for Prometheus data retention (used by compose configs)
PROMETHEUS_RETENTION=15d

# ==================================================================
# Development Tools
# ==================================================================
# Portainer for container management
PORTAINER_PORT=9000

# ==================================================================
# SSL/TLS Configuration (Optional)
# ==================================================================
# Set to true to enable HTTPS in development
ENABLE_HTTPS=false

# Certificate paths (if HTTPS is enabled)
HTTPS_CERT_PATH=
HTTPS_KEY_PATH=

# ==================================================================
# JWT Configuration (Identity.API + Basket/Ordering/Catalog APIs)
# ==================================================================
# Use the same values across identity.api, basket.api, ordering.api, and catalog.api.
JWT_SECRET=dev-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ISSUER=http://localhost:8010
JWT_AUDIENCE=ecommerce-api
JWT_EXPIRY_MINUTES=60

# Seeded demo users (Identity.API startup seed):
#   demo@retailmesh.com / Demo@12345
#   admin@retailmesh.com / Admin@12345

# ==================================================================
# CORS Configuration
# ==================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:4200,https://localhost:4200

# ==================================================================
# File Upload Configuration
# ==================================================================
# Maximum file upload size in bytes
MAX_UPLOAD_SIZE=10485760  # 10MB

# Upload directory
UPLOAD_DIRECTORY=./uploads

# ==================================================================
# Cache Configuration
# ==================================================================
# Cache expiration times in minutes
CATALOG_CACHE_EXPIRY=30
BASKET_CACHE_EXPIRY=60
DISCOUNT_CACHE_EXPIRY=120

# ==================================================================
# Rate Limiting Configuration
# ==================================================================
# API rate limiting settings
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# ==================================================================
# Health Check Configuration
# ==================================================================
# Health check endpoints timeout in seconds
HEALTH_CHECK_TIMEOUT=30

# ==================================================================
# Email Configuration (Optional)
# ==================================================================
# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ecommerce.com
SMTP_ENABLE_SSL=true

# ==================================================================
# External API Keys (Optional)
# ==================================================================
# Third-party service API keys
PAYMENT_GATEWAY_API_KEY=
SHIPPING_API_KEY=
ANALYTICS_API_KEY=
