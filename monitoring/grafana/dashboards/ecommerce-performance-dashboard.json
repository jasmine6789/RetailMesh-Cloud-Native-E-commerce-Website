      },
      "targets": [
        {
          "expr": "up{job=~\"catalog-api|basket-api|ordering-api|ocelot-api-gateway|prometheus\"}",
          "legendFormat": "{{job}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
